# Server
PORT=3001
NODE_ENV=production

# Database
# Railway: Use mounted volume at /app/data
DB_PATH=/app/data/fashion_shop.db
# Local: ./data/fashion_shop.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
# Add your frontend domain (Vercel: *.vercel.app, Railway backend: *.railway.app)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://*.vercel.app,https://*.railway.app

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5000000

# Momo Payment (https://test-payment.momo.vn)
MOMO_PARTNER_CODE=MOMO_TEST
MOMO_ACCESS_KEY=your-access-key
MOMO_SECRET_KEY=your-secret-key
# Set to your frontend domain (Vercel)
MOMO_REDIRECT_URL=https://your-app.vercel.app/api/payment/momo/return
MOMO_IPN_URL=https://your-backend.railway.app/api/payment/momo/ipn

# VNPay (https://sandbox.vnpayment.vn)
VNPAY_TMN_CODE=your-tmn-code
VNPAY_HASH_SECRET=your-hash-secret
VNPAY_URL=https://sandbox.vnpayment.vn
VNPAY_RETURN_URL=https://your-app.vercel.app/api/payment/vnpay/return
VNPAY_IPN_URL=https://your-backend.railway.app/api/payment/vnpay/ipn

# Admin (optional)
ADMIN_EMAIL=admin@fashionshop.com

# Logging
LOG_LEVEL=info
